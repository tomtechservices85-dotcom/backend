generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id         Int     @id @default(autoincrement())
  name       String
  price      Float
  images     Json
  categories Json
  comment    String?
}

model User {
  id       Int    @id @default(autoincrement())
  email    String @unique
  password String
  role     String @default("admin")
}
